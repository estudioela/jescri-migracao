# Template das variáveis lidas pelo próprio docker-compose.yml (raiz do
# repositório), distinto de `backend/.env` (config do Laravel).
# Copie para `.env` nesta mesma pasta e ajuste os valores reais.
#
# Escopo desta sprint (5.2.1): apenas a variável de build do frontend.
# DB_PASSWORD/DB_DATABASE/DB_USERNAME (interpolação do serviço `db`) ficam
# fora desta sprint — ver docs/deployment/IMPLEMENTACAO_TECNICA.md §3/§9.

# URL da API consumida pelo frontend, baked into o bundle estático no
# build (ver frontend/Dockerfile) — sem isso, cai no default de
# desenvolvimento (http://localhost:8000/api).
VITE_API_URL=https://CHANGE_ME/api
