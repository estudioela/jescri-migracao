APP_NAME="ELÃ | influência"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# Sem default no config/session.php (env(SESSION_SECURE_COOKIE) sem segundo
# argumento) — se esta linha for omitida, o cookie de sessão trafega sem a
# flag Secure mesmo atrás de HTTPS. false é correto aqui (dev usa HTTP);
# OBRIGATÓRIO true em produção (ver .env.production.example).
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=localhost

FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Integração com Google Drive (upload de material). Sem estas 3 variáveis o
# upload é bloqueado (503), sem fallback para armazenamento local — não há
# como demonstrar o fluxo de upload em dev sem credenciais reais.
# Autenticação via OAuth de conta dedicada — pessoal, sem Workspace (ADR-017,
# adendo 2026-07-22), não Service Account Key (bloqueada por Org Policy em
# produção).
# 1. Crie um OAuth Client tipo "Desktop app" no Google Cloud (Device Flow não
#    suporta o escopo `drive` completo — só `drive.file`/`drive.appdata`).
# 2. Rode `php artisan google-drive:obter-refresh-token` e siga o fluxo
#    (abre um servidor loopback local, autorize no navegador).
# 3. Compartilhe a pasta raiz do Drive com a conta dedicada (Content Manager).
# Raiz esperada: https://drive.google.com/drive/u/0/folders/1uSmA2qt8apAkNP54z9yBChhitYXSw2y4
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER_ID=1uSmA2qt8apAkNP54z9yBChhitYXSw2y4
GOOGLE_DRIVE_BACKUP_FOLDER_ID=1c_ImyhRDHGox509kRjTJKHkyiIc5zzBE

# Dashboard de observabilidade em /pulse (restrito a ADMIN). Default do
# pacote é true — só documentado aqui para descoberta (não altera
# comportamento se deixado comentado). Ver docs/MONITORING.md.
# PULSE_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
