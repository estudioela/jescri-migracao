# Template de produção. Copie para `.env` no ambiente de produção/homologação
# e preencha os valores marcados com CHANGE_ME. Não use `.env.example` (esse
# é o template de desenvolvimento local, com defaults inseguros de propósito
# — SQLite, debug ligado, cookie não-seguro).
#
# Ver docs/release/TEAR_V2.5_GO_LIVE_CHECKLIST.md para o checklist completo de deploy.

APP_NAME="TEAR"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://influencia.estudioela.com

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
# Default do Laravel é 14 — explícito aqui para não depender de um
# default implícito em auditoria futura. Ajustar conforme exigência de
# retenção do negócio.
LOG_DAILY_DAYS=30

# SQLite não suporta escrita concorrente — inadequado em produção porque
# sessions/cache/queue (abaixo) escrevem no banco a cada request. Ver §5 do
# roadmap de produtização.
# Host/porta/credenciais do PostgreSQL gerenciado do plano Locaweb (Etapa 2
# de docs/deployment/PLANO_IMPLEMENTACAO.md) — nunca um serviço docker-compose.
DB_CONNECTION=pgsql
DB_HOST=CHANGE_ME
DB_PORT=5432
DB_DATABASE=CHANGE_ME
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# IP(s)/CIDR do proxy reverso da Locaweb (confirmado na Etapa 1 do plano de
# implantação). Vazio = nenhum proxy confiado (comportamento atual, seguro).
TRUSTED_PROXIES=CHANGE_ME

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Obrigatório com HTTPS em produção — sem isto o cookie de sessão trafega
# sem a flag Secure.
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
# Origem única para frontend e backend (ADR-015 — Laravel serve o build do
# Vite a partir de public/build, sem subdomínio separado para a SPA): sem
# ponto inicial, host exato do único subdomínio.
SESSION_DOMAIN=influencia.estudioela.com

# Mesma origem de APP_URL (ADR-015) — não é mais um subdomínio distinto.
FRONTEND_URL=https://influencia.estudioela.com
# Mesmo host de APP_URL, sem protocolo.
SANCTUM_STATEFUL_DOMAINS=influencia.estudioela.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS="CHANGE_ME"
MAIL_FROM_NAME="${APP_NAME}"

# Sem estas 4 variáveis o upload de Material é bloqueado (503 — "Envio de
# materiais está temporariamente indisponível"), sem fallback para
# armazenamento local. Obrigatório preencher antes do Go-Live.
# Autenticação via OAuth de conta dedicada — pessoal, sem Workspace (ADR-017,
# adendo 2026-07-22), não Service Account Key — bloqueada por Org Policy
# (iam.disableServiceAccountKeyCreation) em elafashionmkt-org.
# CLIENT_ID/CLIENT_SECRET vêm do OAuth Client tipo "Desktop app" no Cloud
# Console (Device Flow não suporta o escopo `drive` completo); REFRESH_TOKEN
# vem de `php artisan google-drive:obter-refresh-token`.
GOOGLE_DRIVE_CLIENT_ID=CHANGE_ME
GOOGLE_DRIVE_CLIENT_SECRET=CHANGE_ME
GOOGLE_DRIVE_REFRESH_TOKEN=CHANGE_ME
GOOGLE_DRIVE_ROOT_FOLDER_ID=1uSmA2qt8apAkNP54z9yBChhitYXSw2y4
# Subpasta dedicada a backup de banco, dentro da mesma pasta raiz acima
# (Etapa 5 de docs/deployment/PLANO_DE_IMPLANTACAO.md, `ADR-017`). Usada
# pelo comando `backup:upload-to-drive`.
GOOGLE_DRIVE_BACKUP_FOLDER_ID=1c_ImyhRDHGox509kRjTJKHkyiIc5zzBE

# Dashboard de observabilidade em /pulse (restrito a ADMIN). Funciona com
# os defaults abaixo — só documentado aqui para descoberta. Ver
# docs/MONITORING.md.
# PULSE_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
