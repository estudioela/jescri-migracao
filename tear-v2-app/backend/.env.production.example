# Template de produção. Copie para `.env` no ambiente de produção/homologação
# e preencha os valores marcados com CHANGE_ME. Não use `.env.example` (esse
# é o template de desenvolvimento local, com defaults inseguros de propósito
# — SQLite, debug ligado, cookie não-seguro).
#
# Ver TEAR_V2.5_GO_LIVE_CHECKLIST.md para o checklist completo de deploy.

APP_NAME="TEAR"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://CHANGE_ME

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
# Default do Laravel é 14 — explícito aqui para não depender de um
# default implícito em auditoria futura. Ajustar conforme exigência de
# retenção do negócio.
LOG_DAILY_DAYS=30

# SQLite não suporta escrita concorrente — inadequado em produção porque
# sessions/cache/queue (abaixo) escrevem no banco a cada request. Ver §5 do
# roadmap de produtização.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=tear
DB_USERNAME=tear
DB_PASSWORD=CHANGE_ME

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Obrigatório com HTTPS em produção — sem isto o cookie de sessão trafega
# sem a flag Secure.
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=.CHANGE_ME.com.br

FRONTEND_URL=https://CHANGE_ME
SANCTUM_STATEFUL_DOMAINS=CHANGE_ME

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS="CHANGE_ME"
MAIL_FROM_NAME="${APP_NAME}"

# Sem estas 3 variáveis o upload de Material cai em armazenamento local
# (disco "public", dentro do container — não é persistente/compartilhado
# entre réplicas). Preencher antes de operar com mais de uma instância.
GOOGLE_DRIVE_CLIENT_EMAIL=CHANGE_ME
GOOGLE_DRIVE_PRIVATE_KEY=CHANGE_ME
GOOGLE_DRIVE_ROOT_FOLDER_ID=CHANGE_ME

# Dashboard de observabilidade em /pulse (restrito a ADMIN). Funciona com
# os defaults abaixo — só documentado aqui para descoberta. Ver
# docs/MONITORING.md.
# PULSE_ENABLED=true

VITE_APP_NAME="${APP_NAME}"
