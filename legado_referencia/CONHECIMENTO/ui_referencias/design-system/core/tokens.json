      },
      "label": {
        "$value": "'Archivo Narrow', 'Segoe UI', Helvetica, Arial, sans-serif",
        "$type": "fontFamily",
        "$description": "SUBSTITUTO. Sem serifa condensada, para rótulos."
      },
      "body": {
        "$value": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
        "$type": "fontFamily",
        "$description": "SUBSTITUTO. Sem serifa, para corpo de texto."
      }
    },
    "font-weight": {
      "regular": { "$value": "400", "$type": "fontWeight" },
