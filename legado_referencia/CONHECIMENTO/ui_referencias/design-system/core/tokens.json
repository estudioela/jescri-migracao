    "typography": {
      "display": {
        "family": { "$value": "{primitive.font-family.display}", "$type": "fontFamily" },
        "style": { "$value": "{primitive.font-style.italic}", "$type": "string" },
        "weight": { "$value": "{primitive.font-weight.regular}", "$type": "fontWeight" }
      },
      "label": {
        "family": { "$value": "{primitive.font-family.label}", "$type": "fontFamily" },
        "weight": { "$value": "{primitive.font-weight.semibold}", "$type": "fontWeight" }
      },
      "body": {
        "family": { "$value": "{primitive.font-family.body}", "$type": "fontFamily" },
        "weight": { "$value": "{primitive.font-weight.regular}", "$type": "fontWeight" }
      }
    },
    "case": {
      "brand": { "$value": "lowercase", "$type": "string", "$description": "VERIFICADO. Todo texto da marca é minúsculo. Nenhum produto Elã usa caixa alta." }
    }
  }
}
