        "out": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" }
      }
    },
    "breakpoint": {
      "md": { "$value": "768px", "$type": "dimension" }
    }
  },
  "semantic": {
    "color": {
      "background": { "$value": "{primitive.color.neutral-50}", "$type": "color" },
      "surface": { "$value": "{primitive.color.white}", "$type": "color" },
      "surface-container": { "$value": "{primitive.color.neutral-150}", "$type": "color" },
      "surface-container-low": { "$value": "{primitive.color.neutral-100}", "$type": "color" },
      "surface-container-high": { "$value": "{primitive.color.neutral-200}", "$type": "color" },
      "content": { "$value": "{primitive.color.neutral-950}", "$type": "color" },
      "content-muted": { "$value": "{primitive.color.neutral-700}", "$type": "color" },
      "content-faint": { "$value": "{primitive.color.neutral-500}", "$type": "color" },
      "content-on-accent": { "$value": "{primitive.color.white}", "$type": "color" },
      "border-subtle": { "$value": "rgba(145, 111, 106, 0.25)", "$type": "color" },
      "accent": { "$value": "{primitive.color.brand-600}", "$type": "color" },
      "accent-strong": { "$value": "{primitive.color.brand-700}", "$type": "color" },
      "danger": { "$value": "{primitive.color.danger}", "$type": "color" }
