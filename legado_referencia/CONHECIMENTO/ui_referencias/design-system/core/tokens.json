      "brand-700": { "$value": "#8a1e1a", "$type": "color", "$description": "INFERIDO. Escurecimento de brand-600 para estados de ênfase." },
      "brand-500": { "$value": "#b8433f", "$type": "color", "$description": "INFERIDO. Clareamento de brand-600." },
      "danger": { "$value": "#ba1a1a", "$type": "color", "$description": "INFERIDO. Vermelho de erro, distinto do vermelho de marca por decisão de acessibilidade." },
      "neutral-950": { "$value": "#1c1b1b", "$type": "color", "$description": "INFERIDO." },
      "neutral-700": { "$value": "#5d3f3b", "$type": "color", "$description": "INFERIDO. Neutro quente." },
      "neutral-500": { "$value": "#916f6a", "$type": "color", "$description": "INFERIDO. Neutro quente." },
      "neutral-200": { "$value": "#ece7e7", "$type": "color", "$description": "INFERIDO." },
      "neutral-150": { "$value": "#f1edec", "$type": "color", "$description": "INFERIDO." },
      "neutral-100": { "$value": "#f7f2f2", "$type": "color", "$description": "INFERIDO." },
      "neutral-50": { "$value": "#fdf8f8", "$type": "color", "$description": "INFERIDO." },
      "white": { "$value": "#ffffff", "$type": "color" }
    },
    "font-family": {
      "display": {
        "$value": "'EB Garamond', Georgia, 'Times New Roman', serif",
